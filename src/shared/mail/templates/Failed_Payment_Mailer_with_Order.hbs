{{> header}}
<!-- Welcome Banner -->
<tr>
    <td style="padding: 35px 40px 30px 40px; text-align: center; background-color: #ffffff;">
        <h1
            style="margin: 0; font-size: 26px; font-weight: 700; color: #082c4b; letter-spacing: -0.3px; line-height: 1.3;">
            Payment Failed for Your Order #{{orderId}} </h1>
        <div
            style="width: 50px; height: 6px; background-color: #0a5cc0; border-radius: 10px; margin: 15px auto 0 auto;">
        </div>
    </td>
</tr>

<!-- Main Content Section -->
<tr>
    <td style="padding: 0 40px 35px 40px; background-color: #ffffff;">
        <p style="margin: 0 0 15px 0; font-size: 11pt; color: #212529; line-height: 1.6; font-weight: 400;">
            Hi <strong style="font-weight: 600; color: #082c4b;">{{name}}</strong>,</p>

        <p style="margin: 0 0 10px 0; font-size: 11pt; color: #212529; line-height: 1.6; font-weight: 400;">
            We regret to inform you that your recent payment attempt for your IndiGalleria order could
            not be completed.</p>


        <!-- Reasons List -->
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 12px;">
            <tr>
                <td style="padding: 3px 0;">
                    <p style="margin: 0; font-size: 11pt; color: #212529; line-height: 1.5; font-weight: bold;">
                        There may be a few possible reasons for this:

                    </p>
                </td>
            </tr>

            <tr>
                <td style="padding: 3px 0;">
                    <p style="margin: 0; font-size: 11pt; color: #212529; line-height: 1.5; font-weight: 400;">

                        • Incorrect card/bank details: Please double-check the information entered to
                        ensure it’s accurate and matches your bank records.
                    </p>
                </td>
            </tr>

            <tr>
                <td style="padding: 3px 0;">
                    <p style="margin: 0; font-size: 11pt; color: #212529; line-height: 1.5; font-weight: 400;">
                        • Payment declined by your bank: Kindly contact your bank to inquire about the
                        declined transaction or to complete any required authorization.
                    </p>
                </td>
            </tr>

            <tr>
                <td style="padding: 3px 0;">
                    <p style="margin: 0; font-size: 11pt; color: #212529; line-height: 1.5; font-weight: 400;">
                        • Technical issues: Temporary technical problems can sometimes interrupt
                        transactions.
                    </p>
                </td>
            </tr>

            <tr>
                <td style="padding: 3px 0;">
                    <p style="margin: 0; font-size: 11pt; color: #212529; line-height: 1.5; font-weight: 400;">
                        • Payment cancelled by user
                    </p>
                </td>
            </tr>
        </table>

        <p style="margin: 0 0 18px 0; font-size: 11pt; color: #212529; line-height: 1.6; font-weight: 400;">
            We request you to retry the payment by visiting your <a href="https://www.indigalleria.com/order-summary"
                style="color: #00b1c8; text-decoration: none; font-weight: 500;">Order Summary /
                Payment Link</a>, or feel free to place the order again.</p>

        <!-- Order Details -->
        <p style="margin: 0 0 3px 0; font-size: 11pt; color: #212529; line-height: 1.6; font-weight: 400;">
            <strong>Order Details:</strong>
        </p>
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 10px;">
            <tr>
                <td style="padding: 3px 0;">
                    <p style="margin: 0; font-size: 11pt; color: #212529; line-height: 1.5; font-weight: 400;">
                        Order ID: <strong>{{orderId}}</strong>
                    </p>
                </td>
            </tr>

            <tr>
                <td style="padding: 3px 0;">

                   
                    <p style="margin: 0; font-size: 11pt; color: #212529; line-height: 1.5; font-weight: 400;">
                        Artwork Title: <strong> {{#each items}}{{productName}}, {{/each}}</strong>
                    </p>
                   
                </td>
            </tr>

            <tr>
                <td style="padding: 3px 0;">
                    <p style="margin: 0; font-size: 11pt; color: #212529; line-height: 1.5; font-weight: 400;">
                        Total Amount: <strong>{{currency}}{{totalAmount}}</strong>
                    </p>
                </td>
            </tr>

            <tr>
                <td style="padding: 3px 0;">
                    <p style="margin: 0; font-size: 11pt; color: #212529; line-height: 1.5; font-weight: 400;">
                        Order Date: <strong>{{orderDate}}</strong>
                    </p>
                </td>
            </tr>

            <tr>
                <td style="padding: 3px 0;">
                    <p style="margin: 0; font-size: 11pt; color: #212529; line-height: 1.5; font-weight: 400;">
                        Payment Gateway: <strong>{{paymentGatway}}</strong>
                    </p>
                </td>
            </tr>

            <tr>
                <td style="padding: 3px 0;">
                    <p style="margin: 0; font-size: 11pt; color: #212529; line-height: 1.5; font-weight: 400;">
                        Payment Status: <strong>{{paymentStatus}}</strong>
                    </p>
                </td>
            </tr>

            <tr>
                <td style="padding: 3px 0;">
                    <p style="margin: 0; font-size: 11pt; color: #212529; line-height: 1.5; font-weight: 400;">
                        Order Status: <strong>{{orderStatus}}</strong>
                    </p>
                </td>
            </tr>
        </table>

        <p style="margin: 0 0 10px 0; font-size: 11pt; color: #212529; line-height: 1.6; font-weight: 400;">
            If the amount has been debited from your account but the payment status still shows as
            failed, please allow 24-48 hours for it to reflect. If the issue persists, feel free to
            reach out to our support team at
            <a href="mailto:info@indigalleria.com"
                style="color: #00b1c8; text-decoration: none; font-weight: 500;">info@indigalleria.com</a>
            or message us on WhatsApp at
            <a href="https://wa.me/919555511765" style="color: #00b1c8; text-decoration: none; font-weight: 500;">+91
                9555511765</a>.
        </p>

        <p style="margin: 0 0 18px 0; font-size: 11pt; color: #212529; line-height: 1.6; font-weight: 400;">
            Thank you for your interest in owning original, authenticated artwork through
            IndiGalleria.</p>
        <p style="margin: 0 0 10px 0; font-size: 11pt; color: #212529; line-height: 1.6; font-weight: 400;">



            Best regards,<br>
            Team IndiGalleria
        </p>
    </td>
</tr>

<!-- CTA Button Section -->


{{> footer}}